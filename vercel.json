{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/",
      "dest": "/pages/index.html"
    },
    {
      "src": "/problems",
      "dest": "/pages/problems.html"
    },
    {
      "src": "/problem",
      "dest": "/pages/problem.html"
    },
    {
      "src": "/daily",
      "dest": "/pages/daily.html"
    },
    {
      "src": "/topics",
      "dest": "/pages/topics.html"
    },
    {
      "src": "/leaderboard",
      "dest": "/pages/leaderboard.html"
    },
    {
      "src": "/login",
      "dest": "/pages/login.html"
    },
    {
      "src": "/signup",
      "dest": "/pages/signup.html"
    },
    {
      "src": "/profile",
      "dest": "/pages/profile.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    }
  ]
}
